# ── Root env for docker-compose ─────────────────────────────────────────────
# Copy to `.env` before running `docker compose up`.

# Postgres (local container)
POSTGRES_USER=crux
POSTGRES_PASSWORD=crux
POSTGRES_DB=crux

# Backend
JWT_SECRET=change-me-to-a-long-random-string
# When running via docker-compose the backend reaches Postgres at host `db`:
DATABASE_URL=postgresql+psycopg2://crux:crux@db:5432/crux
CORS_ORIGINS=http://localhost:3000

# Optional third-party keys (add per client as you receive them)
GEMINI_API_KEY=
RESEND_API_KEY=
SUPABASE_URL=https://kiupgoucjytmuxygblps.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Aether AI ────────────────────────────────────────────────────────────────
# LLM providers (any subset works; with none set, deterministic mock mode runs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY above is reused by Aether

# Meta Marketing API publishing (blueprints publish PAUSED)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_PIXEL_ID=

# Celery / Redis (leave empty to run tasks in-process, no Redis needed)
REDIS_URL=redis://redis:6379/0

# Stripe billing (mock mode without keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Observability (optional)
POSTHOG_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
