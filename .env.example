# ── Root env for docker-compose ─────────────────────────────────────────────
# Copy to `.env` before running `docker compose up`.

# Postgres (local container)
POSTGRES_USER=crux
POSTGRES_PASSWORD=crux
POSTGRES_DB=crux

# Backend
JWT_SECRET=change-me-to-a-long-random-string
# When running via docker-compose the backend reaches Postgres at host `db`:
DATABASE_URL=postgresql+psycopg2://crux:crux@db:5432/crux
CORS_ORIGINS=http://localhost:3000

# Optional third-party keys (add per client as you receive them)
GEMINI_API_KEY=
RESEND_API_KEY=
SUPABASE_URL=https://kiupgoucjytmuxygblps.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
