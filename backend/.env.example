# ============================================================================
# CRUX backend — environment variables
# Copy to `.env` and fill in the blanks.  Never commit the real .env file.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use a local SQLite file (instant dev, zero setup).
#
# Local Docker Postgres (docker-compose up):
#   DATABASE_URL=postgresql+psycopg2://crux:crux@localhost:5432/crux
#
# Supabase (project ref: kiupgoucjytmuxygblps) — use the DIRECT connection
# string from Dashboard ▸ Settings ▸ Database ▸ Connection string ▸ URI, and
# swap the scheme to `postgresql+psycopg2://`. Example:
#   DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-DB-PASSWORD]@db.kiupgoucjytmuxygblps.supabase.co:5432/postgres
DATABASE_URL=

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=120

# First-run admin (created by `python -m app.seed`)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_EMAIL=admin@dizigroww.com

# ── Supabase (Storage + client SDK) ─────────────────────────────────────────
SUPABASE_URL=https://kiupgoucjytmuxygblps.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=crux-documents

# ── Third-party marketing / AI APIs (optional — add per client) ─────────────
GEMINI_API_KEY=
RESEND_API_KEY=
[email protected]

# Meta Marketing API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Shopify Admin API
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=

# WooCommerce REST API
WOOCOMMERCE_URL=
WOOCOMMERCE_KEY=
WOOCOMMERCE_SECRET=

# Google Analytics 4 + Search Console (service-account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=
